{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ESNext"],
    "module": "commonjs",
    "noEmit": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true
  },
  "include": ["src", "./index.ts"],
  "exclude": ["node_modules", "dist"]
}
